# Environment Variables - Template
# Copy this file to .env or .env.local and update values as needed

# Application Base URL (required)
BASE_URL=http://localhost:4200

# Test Execution Configuration (optional)
# Number of parallel workers - defaults: 50% (local), 2 (CI)
# Uncomment and set to override:
# WORKERS=4

# CI environment flag (auto-detected by CI platforms like GitHub Actions)
# Uncomment only if needed for local testing:
# CI=true
